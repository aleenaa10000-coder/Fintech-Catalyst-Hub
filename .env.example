# =============================================================================
# FintechPressHub — environment template
# =============================================================================
# Copy this file to `.env` for local development, or — when running on Replit —
# add each variable as a Secret in the Secrets pane (Tools → Secrets).
# Never commit a populated `.env` file.
# =============================================================================

# ----- Database (required) ---------------------------------------------------
# A Postgres connection string. On Replit, provision the built-in PostgreSQL
# database from the Database tool and `DATABASE_URL` will be set automatically.
DATABASE_URL=postgres://user:password@host:5432/dbname

# ----- API server (required) -------------------------------------------------
# Port the Express API binds to. The frontend's Vite dev server proxies
# requests at /api to this port (see artifacts/fintechpresshub/vite.config.ts).
PORT=8080
NODE_ENV=development

# Optional override for the Vite dev proxy target. Defaults to
# http://127.0.0.1:8080 if unset.
# API_PROXY_TARGET=http://127.0.0.1:8080

# ----- Frontend dev server ---------------------------------------------------
# When running locally these are the defaults the Replit workflow uses.
# Override to change the dev server port.
# PORT=5173
# BASE_PATH=/

# ----- Email / notifications (optional) -------------------------------------
# Two delivery options — only one is required:
#
# Option A: Resend (recommended for Replit deployments)
#   Sign up at resend.com, verify your domain, then set the API key below.
#   REPORT_FROM_EMAIL accepts "Name <addr@domain>" format.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
REPORT_FROM_EMAIL=FintechPressHub <hello@yourdomain.com>
#
# Option B: SMTP (any provider)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=postmaster@example.com
SMTP_PASS=changeme
#
# Destination addresses for notification emails.
# Strip any surrounding parentheses or angle brackets — use plain addresses.
PITCH_RECIPIENT_EMAIL=editorial@example.com
CONTACT_NOTIFY_TO=hello@example.com

# ----- Admin allowlist (required to publish from /admin/blog) ---------------
# Comma-separated, case-insensitive list of Replit account emails allowed to
# sign in to /admin/blog and publish/edit/delete posts. Anyone not on this
# list (or signed out) cannot hit the write endpoints — they get 401/403 and
# the admin UI shows a "not authorized" screen.
# Set to your own Replit account email to unlock the admin UI.
ADMIN_EMAILS=you@example.com,teammate@example.com
