modules = ["nodejs-20", "web", "bash", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c 'cd artifacts/api-server && export PORT=8080 NODE_ENV=development && pnpm run build && node --enable-source-maps ./dist/index.mjs'"
waitForPort = 8080

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c 'cd artifacts/fintechpresshub && export PORT=5000 BASE_PATH=/ NODE_ENV=development API_PROXY_TARGET=http://127.0.0.1:8080 && pnpm run dev'"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["javascript_object_storage:2.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 18082
externalPort = 3003

[[ports]]
localPort = 21096
externalPort = 3000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
REPORT_FROM_EMAIL = "FintechPressHub <onboarding@resend.dev>"
ADMIN_EMAILS = "hello@fintechpresshub.com,jasmine.offpageseospecialist@hotmail.com"
